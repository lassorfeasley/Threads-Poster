# --- YouTube Data API v3 (discovery only; no downloading happens with this key) ---
YOUTUBE_API_KEY=

# --- LLM (relevance scoring, comment classification, reply drafts) ---
ANTHROPIC_API_KEY=

# --- Database ---
# Leave empty (or omit) to use local SQLite at data/app.db — recommended for
# day-to-day development on this machine (page loads stay under ~100ms).
# For a shared / product deployment use Supabase Postgres (Project Settings →
# Database). Remote DBs add ~100ms per query; the app batches queries for that
# case, but local SQLite is still much snappier for UI work.
# DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# --- Supabase Storage (hosts trimmed clips so Threads can fetch them by URL) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Threads / Meta app (create at developers.facebook.com, Threads use case) ---
THREADS_APP_ID=
THREADS_APP_SECRET=
# Must match a redirect URI registered on the Meta app (HTTPS required by Meta).
THREADS_REDIRECT_URI=https://localhost/threads/callback
